{
  "info": {
    "_postman_id": "parivar-collection-v1",
    "name": "Parivar API Collection",
    "description": "Collection for Parivar API - grouped folder-wise. All variables pre-configured.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Authentication token (Bearer token) - Update after login"
    },
    {
      "key": "phone_number",
      "value": "9876543210",
      "type": "string",
      "description": "Test phone number for authentication"
    },
    {
      "key": "email",
      "value": "john@example.com",
      "type": "string",
      "description": "Test email for user login/registration"
    },
    {
      "key": "password",
      "value": "12345",
      "type": "string",
      "description": "Test password for user login/registration"
    },
    {
      "key": "otp",
      "value": "123456",
      "type": "string",
      "description": "One-Time Password for OTP verification"
    },
    {
      "key": "user_id",
      "value": "12345",
      "type": "string",
      "description": "Test user ID for API calls"
    },
    {
      "key": "member_id",
      "value": "12345",
      "type": "string",
      "description": "Test member ID for directory operations"
    },
    {
      "key": "country_id",
      "value": "1",
      "type": "string",
      "description": "Test country ID"
    },
    {
      "key": "state_id",
      "value": "1",
      "type": "string",
      "description": "Test state ID"
    },
    {
      "key": "city_id",
      "value": "1",
      "type": "string",
      "description": "Test city ID"
    },
    {
      "key": "business_category_id",
      "value": "1",
      "type": "string",
      "description": "Test business category ID"
    },
    {
      "key": "post_id",
      "value": "abcd1234",
      "type": "string",
      "description": "Test post ID"
    },
    {
      "key": "business_id",
      "value": "abcd1234",
      "type": "string",
      "description": "Test business ID"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (send OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set('phone_number', pm.request.body.raw.phone_number);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"number\": \"{{phone_number}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login (verify OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"number\": \"{{phone_number}}\", \"otp\": \"{{otp}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Select Account Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"member_id\": \"{{member_id}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/select_account_login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "select_account_login"
              ]
            }
          }
        },
        {
          "name": "Version Code (protected)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/version_code",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "version_code"
              ]
            }
          }
        }
      ]
    },
